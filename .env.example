# Required — alert explanations and incident reports are generated by Claude.
# Without a real key here, the app still runs but falls back to a static template.
ANTHROPIC_API_KEY=your_key_here

# Optional: a Slack/Discord/MS Teams incoming webhook URL (or any custom endpoint that
# accepts a JSON POST). Critical/extreme alerts get pushed here in addition to the
# dashboard. Leave blank to skip external notifications entirely.
ALERT_WEBHOOK_URL=

# Optional: a real phone call (via Twilio Programmable Voice) for EXTREME-severity
# alerts only. All four must be set or this is skipped — no partial config attempts.
# TWILIO_FROM_NUMBER must be a Twilio number capable of outbound voice; ALERT_PHONE_NUMBER
# is the on-call contact to dial, both in E.164 format (e.g. +15551234567). On a Twilio
# trial account, ALERT_PHONE_NUMBER must first be verified in the Twilio console.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_PHONE_NUMBER=

# Optional: a free real-time text alert (via a Telegram bot) for CRITICAL/EXTREME
# alerts — same tier as ALERT_WEBHOOK_URL above, no trial credit or verified-number
# restriction like Twilio SMS. Both required or this is skipped.
#   1. Message @BotFather on Telegram, send /newbot, follow the prompts — it gives you
#      TELEGRAM_BOT_TOKEN.
#   2. Message your new bot anything (or add it to a group), then open
#      https://api.telegram.org/bot<TOKEN>/getUpdates in a browser — the JSON response
#      contains your TELEGRAM_CHAT_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

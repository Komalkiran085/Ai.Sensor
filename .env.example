ANTHROPIC_API_KEY=your_key_here

# Optional: a Slack/Discord/MS Teams incoming webhook URL (or any custom endpoint that
# accepts a JSON POST). Critical/extreme alerts get pushed here in addition to the
# dashboard. Leave blank to skip external notifications entirely.
ALERT_WEBHOOK_URL=

# Which AI backend writes alert explanations and incident reports:
#   ollama (default) — the local model, no API key or cost required
#   claude           — force Claude only (falls back to a static template if the call fails)
#   auto             — Claude if ANTHROPIC_API_KEY is set above, else the local model
LLM_PROVIDER=ollama

# Local model settings (only matter if LLM_PROVIDER can reach "ollama" — i.e. auto or ollama).
# The `ollama` and `ollama-init` services in docker-compose.yml run this automatically;
# OLLAMA_MODEL controls which model ollama-init pulls on first startup.
OLLAMA_MODEL=qwen2.5:3b
